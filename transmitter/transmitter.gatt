PRIMARY_SERVICE, GAP_SERVICE
CHARACTERISTIC, GAP_DEVICE_NAME, READ, "B8_B4"
// Generic Remote Control appearance 384 (0x0180), little-endian.
CHARACTERISTIC, GAP_APPEARANCE, READ, 80 01

PRIMARY_SERVICE, GATT_SERVICE
CHARACTERISTIC, GATT_DATABASE_HASH, READ,

// Control service and readable/notifiable course-protocol characteristic.
PRIMARY_SERVICE, 1848
CHARACTERISTIC, 2A6E, READ | NOTIFY | DYNAMIC,
